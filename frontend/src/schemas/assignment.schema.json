{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "assignment.schema.json",
  "title": "Assignment",
  "description": "Network Lab classroom assignment file format.",
  "type": "object",
  "required": ["title", "topic", "starterNetwork", "allowedAlgorithms", "studentTask"],
  "properties": {
    "assignmentId": { "type": "string", "description": "Unique ID (UUID). Auto-generated if omitted." },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "default": "" },
    "course": { "type": "string", "default": "" },
    "topic": {
      "type": "string",
      "enum": ["ECMP", "DISTANCE_VECTOR", "SEGMENT_ROUTING", "TRAFFIC_ENGINEERING"]
    },
    "mode": {
      "type": "string",
      "enum": ["lecture", "exercise", "challenge"],
      "default": "exercise"
    },
    "starterNetwork": {
      "type": "object",
      "required": ["nodes", "links", "demands", "topologyType", "isDirected"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "x", "y"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "visualType": { "type": "string", "default": "node" }
            }
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "source", "target", "weight", "capacity"],
            "properties": {
              "id": { "type": "string" },
              "source": { "type": "string" },
              "target": { "type": "string" },
              "weight": { "type": "number", "minimum": 0 },
              "capacity": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        },
        "demands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "source", "target", "amount"],
            "properties": {
              "id": { "type": "string" },
              "source": { "type": "string" },
              "target": { "type": "string" },
              "amount": { "type": "number", "minimum": 0 }
            }
          }
        },
        "topologyType": {
          "type": "string",
          "enum": ["custom", "triangle", "line", "ring", "mesh", "fat-tree", "grid", "path", "cycle", "random"]
        },
        "isDirected": { "type": "boolean" }
      }
    },
    "lockedFields": {
      "type": "object",
      "properties": {
        "canEditNodes": { "type": "boolean", "default": false },
        "canEditLinks": { "type": "boolean", "default": false },
        "canEditWeights": { "type": "boolean", "default": true },
        "canEditCapacities": { "type": "boolean", "default": false },
        "canEditDemands": { "type": "boolean", "default": false },
        "canChooseAlgorithm": { "type": "boolean", "default": false }
      }
    },
    "allowedAlgorithms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["ECMP", "DISTANCE_VECTOR", "SEGMENT_ROUTING", "CUSTOM_SPLITTING"] }
    },
    "studentTask": {
      "type": "object",
      "required": ["taskType", "prompt"],
      "properties": {
        "taskType": {
          "type": "string",
          "enum": [
            "SET_LINK_WEIGHTS",
            "IDENTIFY_CONGESTED_LINKS",
            "COMPUTE_PATH_COSTS",
            "COMPUTE_ECMP_SPLIT",
            "COMPUTE_DV_TABLE",
            "REDUCE_MAX_UTILIZATION"
          ]
        },
        "prompt": { "type": "string", "minLength": 1 },
        "instructions": { "type": "string", "default": "" },
        "answerFormatDescription": { "type": "string", "default": "" }
      }
    },
    "expectedSolution": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "properties": {
            "weights": { "type": "object", "additionalProperties": { "type": "number" } },
            "congestedLinks": { "type": "array", "items": { "type": "string" } },
            "pathCosts": { "type": "object", "additionalProperties": { "type": "number" } },
            "trafficSplits": { "type": "object", "additionalProperties": { "type": "number" } },
            "distanceVectorEntries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["nodeId", "destinationId", "cost"],
                "properties": {
                  "nodeId": { "type": "string" },
                  "destinationId": { "type": "string" },
                  "cost": { "type": "number" },
                  "nextHop": { "type": ["string", "null"] }
                }
              }
            },
            "maxUtilizationTarget": { "type": "number", "minimum": 0 },
            "explanation": { "type": "string" }
          }
        }
      ]
    },
    "gradingRules": {
      "type": "object",
      "properties": {
        "tolerance": { "type": "number", "minimum": 0, "default": 0.01 },
        "requireExactLinks": { "type": "boolean", "default": false },
        "allowEquivalentWeights": { "type": "boolean", "default": true },
        "maxScore": { "type": "integer", "minimum": 1, "default": 100 }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
